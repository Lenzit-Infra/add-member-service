# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Comma-separated list of emails allowed to self-claim an admin dashboard account.
ADMIN_EMAILS=admin@example.com

# Long random secret used to sign all auth tokens (access/refresh/claim/reset).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Rotating this logs every signed-in user out.
JWT_SECRET_KEY=

# Where the frontend is served — used to build links inside claim/reset emails.
FRONTEND_URL=http://localhost:5173

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173,https://lenzit.ir,https://www.lenzit.ir

# Set to ".lenzit.ir" in production so the refresh cookie is shared between
# lenzit.ir (frontend) and api.lenzit.ir (backend). Leave empty for local dev.
COOKIE_DOMAIN=
# Set to "true" once the API is served over HTTPS (required in production).
COOKIE_SECURE=false

# SMTP for claim-admin / forgot-password emails.
# Free option: a Gmail account with 2FA enabled + an "App Password"
# (myaccount.google.com/apppasswords) — NOT your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
